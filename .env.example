# Todoist API token (required)
# Generate at: https://app.todoist.com/app/settings/integrations/developer
TODOIST_API_TOKEN=xxxxxxxx

# Write protection (default: false)
# Set to "true" to enable create, update, complete, reopen, delete, batch operations
TODOIST_WRITE_ENABLED=false

# Transport (default: stdio)
TODOIST_MCP_TRANSPORT=stdio
TODOIST_MCP_HOST=127.0.0.1
TODOIST_MCP_PORT=8768

# Bearer token for HTTP transport auth (disabled if empty)
TODOIST_MCP_API_TOKEN=
